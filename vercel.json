    },
    {
      "source": "/legacy-wealth-blueprint-ascension",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/legacy-wealth-blueprint-concierge",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
