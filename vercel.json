{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/challenge",
      "destination": "/challenge/index.html"
    },
    {
      "source": "/challenge/",
      "destination": "/challenge/index.html"
    },
    {
      "source": "/challenge2",
      "destination": "/challenge2/index.html"
    },
    {
      "source": "/challenge2/",
      "destination": "/challenge2/index.html"
    },
    {
      "source": "/challenge3",
      "destination": "/challenge3/index.html"
    },
    {
      "source": "/challenge3/",
      "destination": "/challenge3/index.html"
    },
    {
      "source": "/challengeconfirmation",
      "destination": "/challengeconfirmation.html"
    },
    {
      "source": "/prechallengetraining",
      "destination": "/prechallengetraining.html"
    },
    {
      "source": "/prechallengetraining/",
      "destination": "/prechallengetraining.html"
