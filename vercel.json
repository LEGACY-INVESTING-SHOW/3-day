    {
      "source": "/renewals/index.html",
      "destination": "/renewals",
      "permanent": false
    },
    {
      "source": "/regularticket26.html",
      "destination": "/regularticket26",
      "permanent": false
    },
    {
      "source": "/vipticket26.html",
      "destination": "/vipticket26",
      "permanent": false
    },
    {
      "source": "/taxreport.html",
      "destination": "/taxreport",
      "permanent": false
    },
    {
      "source": "/taxreportvip.html",
      "destination": "/taxreportvip",
      "permanent": false
    },
    {
      "source": "/prepkit.html",
      "destination": "/prepkit",
